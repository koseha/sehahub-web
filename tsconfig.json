{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"strictNullChecks": true,
		"baseUrl": ".",
		"paths": {
			"@*": [
				"src/*"
			]
		},
		"jsx": "preserve",
		"jsxImportSource": "solid-js"
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx",
		"src/**/*.astro",
		"./worker-configuration.d.ts"
	],
	"exclude": [
		"dist",
		"node_modules"
	]
}