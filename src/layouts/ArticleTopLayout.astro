---
import type { CollectionEntry } from "astro:content"
import { Image } from "astro:assets"
import { formatDate, readingTime } from "@lib/utils"
import ArrowIcon from "@components/ArrowIcon.astro"
import { isProject } from "@types"

type Props = {
  entry: CollectionEntry<"projects"> | CollectionEntry<"blog">
}

const { entry } = Astro.props
const { collection, data, body } = entry
const { title, summary, date } = data

const demoUrl = isProject(entry) ? entry.data.demoUrl : null
const storeUrl = isProject(entry) ? entry.data.storeUrl : null
const repoUrl = isProject(entry) ? entry.data.repoUrl : null
const team = isProject(entry) ? entry.data.team : null
const period = isProject(entry) ? entry.data.period : null
// 스토어 슬롯 = storeUrl 기준(있으면 버튼, 없고 MOBILE 단독이면 준비 중 플레이스홀더).
// 데모 슬롯 = MOBILE 단독이면 억제(단 demoUrl 명시 시 노출). demoUrl에 스토어 URL 금지 — storeUrl 필드가 규약.
// DEMO 배지는 웹 라이브 데모 전용, 모바일 앱 스토어 링크에는 붙이지 않는다
const badges = isProject(entry) ? entry.data.badges : null
const isMobileOnly = !!badges && badges.includes("MOBILE") && !badges.includes("WEB") && !badges.includes("DEMO")
const images = isProject(entry) ? entry.data.images : null
---

<div>
  <a href={`/${collection}`} class="group w-fit p-1.5 gap-1.5 text-sm flex items-center border rounded hover:bg-black/5 hover:dark:bg-white/10 border-black/15 dark:border-white/20 transition-colors duration-300 ease-in-out">
    <ArrowIcon direction="left" />
    <div class="w-full group-hover:text-black group-hover:dark:text-white transition-colors duration-300 ease-in-out">
      목록으로
    </div>
  </a>
  <div class="flex flex-wrap text-sm uppercase mt-12 gap-3 opacity-75">
    <div class="flex items-center gap-2">
      <svg class="size-5 stroke-current" aria-hidden="true">
        <use href="/ui.svg#calendar"/>
      </svg>
      <span class="sr-only">기간 </span>{period ?? formatDate(date)}
    </div>
    {team && (
      <div class="flex items-center gap-2 border-l border-black/15 dark:border-white/25 pl-3">
        <svg class="size-5 stroke-current" aria-hidden="true">
          <use href="/ui.svg#users"/>
        </svg>
        <span class="sr-only">팀 구성 </span>{team}
      </div>
    )}
    {collection === "blog" && (
      <div class="flex items-center gap-2">
        <svg class="size-5 stroke-current">
          <use href="/ui.svg#book-open"/>
        </svg>
        {readingTime(body)}
      </div>
    )}
  </div>
  <h1 class="text-3xl font-semibold text-black dark:text-white mt-2">
    {title}
  </h1>
  <div class="mt-1">
    {summary}
  </div>
  {collection === "projects" &&
  <div class="mt-4 flex flex-wrap gap-2">
    {storeUrl ?
      <a href={storeUrl} target="_blank" class="group flex gap-2 items-center px-3 py-1.5 truncate rounded text-xs md:text-sm lg:text-base border border-black/25 dark:border-white/25 hover:bg-black/5 hover:dark:bg-white/15 blend">
        <svg class="size-4">
          <use href="/ui.svg#globe" class="fill-current group-hover:fill-black group-hover:dark:fill-white blend"/>
        </svg>
        <span class="text-current group-hover:text-black group-hover:dark:text-white blend">
          App Store
        </span>
      </a>
      : isMobileOnly &&
      <span class="flex gap-2 items-center px-3 py-1.5 truncate rounded text-xs md:text-sm lg:text-base border border-black/15 dark:border-white/20 opacity-60">
        App Store 출시 준비 중
      </span>
    }
    {(!isMobileOnly || demoUrl) && (demoUrl ?
      <a href={demoUrl} target="_blank" class="group flex gap-2 items-center px-3 py-1.5 truncate rounded text-xs md:text-sm lg:text-base border border-black/25 dark:border-white/25 hover:bg-black/5 hover:dark:bg-white/15 blend">
        <svg class="size-4">
          <use href="/ui.svg#globe" class="fill-current group-hover:fill-black group-hover:dark:fill-white blend"/>
        </svg>
        <span class="text-current group-hover:text-black group-hover:dark:text-white blend">
          라이브 데모
        </span>
      </a>
      :
      <span class="flex gap-2 items-center px-3 py-1.5 truncate rounded text-xs md:text-sm lg:text-base border border-black/15 dark:border-white/20 opacity-60">
        라이브 데모 준비 중
      </span>
    )}
    {repoUrl &&
      <a href={repoUrl} target="_blank" class="group flex gap-2 items-center px-3 py-1.5 truncate rounded text-xs md:text-sm lg:text-base border border-black/25 dark:border-white/25 hover:bg-black/5 hover:dark:bg-white/15 blend">
        <svg class="size-4">
          <use href="/ui.svg#link" class="fill-current group-hover:fill-black group-hover:dark:fill-white blend"/>
        </svg>
        <span class="text-current group-hover:text-black group-hover:dark:text-white blend">
          저장소
        </span>
      </a>
    }
  </div>
  }
  {images && images.length > 0 &&
    <div tabindex="0" role="region" aria-label="스크린샷" class="mt-6 flex gap-4 overflow-x-auto snap-x snap-mandatory pb-2">
      {images.map((img) => (
        <figure class="shrink-0 snap-start">
          <Image src={img.src} alt={img.caption} class="h-[45svh] max-h-[480px] w-auto rounded border border-black/15 dark:border-white/20" />
          <figcaption class="mt-2 text-sm text-center opacity-75">{img.caption}</figcaption>
        </figure>
      ))}
    </div>
  }
</div>
