import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
import { Content } from "./_privacy.md"
---

<PageLayout title="내돈아님 개인정보처리방침" description="내돈아님 앱의 개인정보처리방침입니다.">
  <TopLayout>
    <div class="animate">
      <h1 class="page-heading text-3xl">내돈아님 개인정보처리방침</h1>
      <p class="mt-3 text-sm opacity-75">시행일: 2026년 7월 31일</p>
    </div>
  </TopLayout>
  <BottomLayout>
    <div class="animate">
      <article>
        <Content />
      </article>
    </div>
  </BottomLayout>
</PageLayout>
