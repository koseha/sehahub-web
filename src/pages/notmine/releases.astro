---
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
import { Content } from "./_releases.md"
---

<PageLayout title="내돈아님 업데이트 내역" description="내돈아님 앱의 버전별 변경 사항입니다.">
  <TopLayout>
    <div class="animate">
      <h1 class="page-heading text-3xl">내돈아님 업데이트 내역</h1>
      <p class="mt-3 text-sm opacity-75">버전별 변경 사항을 기록합니다</p>
    </div>
  </TopLayout>
  <BottomLayout>
    <div class="animate">
      <article>
        <Content />
      </article>
    </div>
  </BottomLayout>
</PageLayout>
